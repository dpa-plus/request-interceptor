# Server Ports
PORT_ADMIN=3000
PORT_PROXY=3001

# Database
DATABASE_URL=file:./prisma/dev.db

# Proxy Target
TARGET_URL=http://localhost:8080

# Admin Authentication (default: HTTP Basic Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Optional: Google OAuth instead of Basic Auth. When OAUTH_PROVIDER=google is
# set, ADMIN_USER/ADMIN_PASSWORD are ignored and the UI shows a Sign-in screen.
# Leave OAUTH_PROVIDER empty (or unset) to keep Basic Auth behavior.
# OAUTH_PROVIDER=google
# GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=...
# Comma-separated list of email addresses allowed to sign in.
# GOOGLE_OAUTH_ALLOWED_EMAILS=alice@example.com,bob@example.com
# Optional: also accept any address from these domains (Google Workspace).
# GOOGLE_OAUTH_ALLOWED_DOMAINS=example.com
# Required when OAuth is enabled — secret used to sign session cookies.
# Generate with: openssl rand -hex 32
# SESSION_SECRET=
# Optional: full external base URL of the admin host. If unset, the
# redirect_uri is derived from the incoming request (works behind Traefik /
# nginx with X-Forwarded-Proto + X-Forwarded-Host). Must match what's
# registered in the Google Cloud Console.
# PUBLIC_ADMIN_URL=https://interceptor-admin.example.com

# How many days plaintext auth/cookie headers are kept in the DB before being
# redacted by the cleanup job. 0 (default) = redact immediately on write — the
# UI only ever sees "[REDACTED]" but still surfaces *which* auth headers were
# sent. Increase (e.g. 3) only if you need to inspect tokens during debugging.
AUTH_HEADER_RETENTION_DAYS=0

# Optional: where to store extracted media blobs (images / audio / PDFs / video).
# Defaults to /data/media inside the container.
# MEDIA_DIR=/data/media
