# Server Ports
PORT_ADMIN=3000
PORT_PROXY=3001

# Database
DATABASE_URL=file:./prisma/dev.db

# Proxy Target
TARGET_URL=http://localhost:8080

# Admin Authentication
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# How many days plaintext auth/cookie headers are kept in the DB before being
# redacted by the cleanup job. 0 (default) = redact immediately on write — the
# UI only ever sees "[REDACTED]" but still surfaces *which* auth headers were
# sent. Increase (e.g. 3) only if you need to inspect tokens during debugging.
AUTH_HEADER_RETENTION_DAYS=0

# Optional: where to store extracted media blobs (images / audio / PDFs / video).
# Defaults to /data/media inside the container.
# MEDIA_DIR=/data/media
